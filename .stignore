// Syncthing ignore patterns for bidirectional sync between MacBook (192.168.8.66)
// and pve1 ThinkStation P410 (192.168.8.61).
// .git/ itself IS synced so both sides share one history; only transient locks are skipped.

.DS_Store
._*
.Spotlight-V100
.Trashes
.fseventsd

node_modules
vendor

.git/index.lock
.git/*.lock
.git/objects/pack/tmp_*
.git/HEAD.lock
.git/FETCH_HEAD
.git/ORIG_HEAD

.claude/projects
.claude/shell-snapshots
.claude/todos
.claude/worktrees
.claude/settings.local.json

*.swp
*.swo
*.log
