{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "defaultPalette": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "palette": [
        { "slug": "accent",      "name": "Accent",       "color": "#0099cc" },
        { "slug": "accent-soft", "name": "Accent Soft",  "color": "#00b8e6" },
        { "slug": "accent-deep", "name": "Accent Deep",  "color": "#006c91" },
        { "slug": "signal",      "name": "Signal",       "color": "#1f9d57" },
        { "slug": "alert",       "name": "Alert",        "color": "#c14a1a" },
        { "slug": "indigo",      "name": "Indigo",       "color": "#1a2b4b" },
        { "slug": "indigo-deep", "name": "Indigo Deep",  "color": "#0f1a2e" },
        { "slug": "bg",          "name": "Background",   "color": "#e1e8ed" },
        { "slug": "bg-alt",      "name": "Surface Alt",  "color": "#d6dee4" },
        { "slug": "text",        "name": "Text",         "color": "#0b0b0b" },
        { "slug": "warm",        "name": "Warm",         "color": "#3a3a3a" },
        { "slug": "muted",       "name": "Muted",        "color": "#6a6a6a" },
        { "slug": "dim",         "name": "Dim",          "color": "#9a9a9a" },
        { "slug": "white",       "name": "White (Warm)", "color": "#0c0c0c" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        { "slug": "wordmark",   "name": "Wordmark",        "fontFamily": "\"Chakra Petch\", \"IBM Plex Sans\", system-ui, sans-serif" },
        { "slug": "sans",       "name": "Sans",            "fontFamily": "\"Manrope\", \"IBM Plex Sans\", system-ui, sans-serif" },
        { "slug": "mono",       "name": "Mono",            "fontFamily": "\"IBM Plex Mono\", \"JetBrains Mono\", ui-monospace, monospace" },
        { "slug": "ultra",      "name": "Ultra",           "fontFamily": "\"Major Mono Display\", monospace" },
        { "slug": "ar-display", "name": "Arabic Display",  "fontFamily": "Rakkas, serif" },
        { "slug": "ar-ui",      "name": "Arabic UI",       "fontFamily": "\"Reem Kufi\", Tajawal, system-ui, sans-serif" },
        { "slug": "ar-body",    "name": "Arabic Body",     "fontFamily": "Tajawal, \"Reem Kufi\", system-ui, sans-serif" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vw", "vh"],
      "spacingScale": { "steps": 0 },
      "spacingSizes": [
        { "slug": "10", "name": "Tiny",   "size": "4px" },
        { "slug": "20", "name": "Small",  "size": "8px" },
        { "slug": "30", "name": "Medium", "size": "16px" },
        { "slug": "40", "name": "Large",  "size": "24px" },
        { "slug": "50", "name": "XL",     "size": "40px" },
        { "slug": "60", "name": "2XL",    "size": "64px" }
      ]
    },
    "layout": {
      "contentSize": "1240px",
      "wideSize": "1440px"
    }
  }
}
